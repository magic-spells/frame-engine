{
  "name": "@magic-spells/frame-engine",
  "version": "0.1.0",
  "description": "Calculate intermediate states (tweens) between CSS keyframes",
  "type": "module",
  "main": "dist/frame-engine.min.js",
  "module": "dist/frame-engine.esm.js",
  "types": "dist/frame-engine.d.ts",
  "exports": {
    ".": {
      "types": "./dist/frame-engine.d.ts",
      "import": "./dist/frame-engine.esm.js",
      "require": "./dist/frame-engine.min.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "NODE_ENV=production rollup -c",
    "dev": "NODE_ENV=development rollup -c --watch",
    "prod": "NODE_ENV=production rollup -c --watch"
  },
  "author": "Cory Schulz",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^1.1.1"
  }
}
